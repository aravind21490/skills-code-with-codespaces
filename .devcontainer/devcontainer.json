{
"name":"basic devcontainer",
"image": "mcr.microsoft.com/devcontainers/base:debian",
"postCreateCommand": ".devconatiner/postcreate.sh",
"features": {
	"ghcr.io/devcontainers/features/python:1": {
		"installTools": true,
		"version": "3.10"
	}
},
"customizations": {
	"vscode": {
		"extensions": [
			"ms-python.debugpy",
			"ms-python.python"
		]
	}
}
}